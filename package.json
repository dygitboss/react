{
  "name": "bluereceipt-dashboard",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=12.14.1"
  },
  "proxy": "http://localhost:3001",
  "scripts": {
    "ts:css": "tcm -s -c -p src/**/*.module.scss",
    "start": "concurrently \"npm:ts:css -- -w\" \"react-scripts start\"",
    "build": "npm run ts:css && react-scripts build",
    "test": "concurrently \"npm:ts:css\" \"react-scripts test\"",
    "test:ci": "CI=true concurrently \"npm:ts:css\" \"react-scripts test\"",
    "test:watch": "concurrently \"npm:ts:css -- -w\" \"react-scripts test\"",
    "lint:ts": "tsc && yarn lint:eslint",
    "lint:eslint": "eslint --ext=jsx,ts,tsx 'src/**/*.{ts,tsx}'",
    "lint:css": "stylelint --syntax scss \"src/**/*.scss\"",
    "lint": "yarn run lint:ts && yarn run lint:css",
    "eject": "react-scripts eject",
    "storybook": "start-storybook -p 9009 -s public",
    "build-storybook": "build-storybook -s public -o build/storybook"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@testing-library/dom": "^6.11.0",
    "@testing-library/jest-dom": "^5.0.2",
    "@testing-library/react": "^9.4.0",
    "@testing-library/react-hooks": "^3.2.1",
    "@testing-library/user-event": "^8.0.4",
    "axios": "^0.19.2",
    "classnames": "^2.2.6",
    "node-sass": "^4.13.0",
    "react": "^16.12.0",
    "react-burger-menu": "^2.6.13",
    "react-device-detect": "^1.11.14",
    "react-dom": "^16.12.0",
    "react-hook-form": "^4.6.2",
    "react-redux": "^7.2.0",
    "react-router-dom": "^5.1.2",
    "react-saga": "^0.3.1",
    "react-scripts": "3.3.0",
    "redux": "^4.0.5",
    "redux-devtools-extension": "^2.13.8",
    "redux-logger": "^3.0.6",
    "redux-saga": "^1.1.3",
    "redux-saga-requests": "^0.26.1",
    "redux-saga-requests-axios": "^0.7.7",
    "redux-thunk": "^2.3.0",
    "reselect": "^4.0.0",
    "slate": "^0.57.1",
    "slate-react": "^0.57.1",
    "ts-key-enum": "^2.0.2",
    "typescript": "~3.7.2"
  },
  "devDependencies": {
    "@storybook/addon-actions": "^5.3.4",
    "@storybook/addon-links": "^5.3.4",
    "@storybook/addon-viewport": "^5.3.4",
    "@storybook/addons": "^5.3.4",
    "@storybook/preset-create-react-app": "^1.5.1",
    "@storybook/react": "^5.3.4",
    "@types/classnames": "^2.2.9",
    "@types/jest": "^24.0.0",
    "@types/node": "^12.0.0",
    "@types/node-sass": "^4.11.0",
    "@types/react": "^16.9.0",
    "@types/react-burger-menu": "^2.6.0",
    "@types/react-dom": "^16.9.0",
    "@types/react-redux": "^7.1.7",
    "@types/react-router-dom": "^5.1.3",
    "@types/redux-logger": "^3.0.7",
    "@typescript-eslint/eslint-plugin": "^2.16.0",
    "@typescript-eslint/parser": "^2.16.0",
    "concurrently": "^5.0.2",
    "eslint": "^6.8.0",
    "eslint-config-airbnb-typescript": "^6.3.1",
    "eslint-plugin-import": "^2.20.0",
    "eslint-plugin-jsx-a11y": "^6.2.3",
    "eslint-plugin-react": "^7.17.0",
    "eslint-plugin-react-hooks": "^2.3.0",
    "react-test-renderer": "^16.12.0",
    "serve": "^11.3.0",
    "stylelint": "^13.0.0",
    "stylelint-config-standard": "^19.0.0",
    "typed-css-modules": "^0.6.3"
  }
}
